{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Generated schema for Root",
    "type": "object",
    "properties": {
      "stayDetails": {
        "type": "object",
        "properties": {
          "checkInDateLocal": {
            "type": "string"
          },
          "checkOutDateLocal": {
            "type": "string"
          },
          "rooms": {
            "type": "number"
          },
          "guests": {
            "type": "object",
            "properties": {
              "adults": {
                "type": "number"
              }
            },
            "required": [
              "adults"
            ]
          }
        },
        "required": [
          "checkInDateLocal",
          "checkOutDateLocal",
          "rooms",
          "guests"
        ]
      },
      "propertyFilter": {
        "type": "object",
        "properties": {
          "location": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "coordinates"
              },
              "details": {
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "string"
                  },
                  "longitude": {
                    "type": "string"
                  }
                },
                "required": [
                  "latitude",
                  "longitude"
                ]
              },
              "radius": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "number"
                  },
                  "unit": {
                    "type": "string"
                  }
                },
                "required": [
                  "value",
                  "unit"
                ]
              }
            },
            "required": [
              "type",
              "details",
              "radius"
            ]
          }
        },
        "required": [
          "location"
        ]
      }
    },
    "required": [
      "stayDetails",
      "propertyFilter"
    ]
  }
  